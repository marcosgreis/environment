#!/bin/bash

DATE="$(date +'%Y%m%d')"

NAME="$(echo "$@" | sed 's/ /-/g')"

# BRANCH_NAME="$USER.$NAME.$DATE"
BRANCH_NAME="$USER.$NAME"
DIR_NAME_VISIBLE='~/work/wt/'$NAME
DIR_NAME=~/work/wt/$NAME

if [[ "${#BRANCH_NAME}" -gt 55 ]]; then
  echo "Branch name is over 55 charaters: '$BRANCH_NAME ' (size: ${#BRANCH_NAME})"
  exit 1
fi

echo "Creating worktree '$BRANCH_NAME' at $DIR_NAME_VISIBLE (size: ${#BRANCH_NAME})"
pause

git worktree add -b $BRANCH_NAME $DIR_NAME && cd $DIR_NAME
